FROM golang:1.26.4-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY cmd/ cmd/
COPY internal/ internal/
RUN CGO_ENABLED=0 go build -o /kiviq-agent ./cmd/agent

FROM alpine:3.19
RUN apk add --no-cache ca-certificates docker-cli
COPY --from=build /kiviq-agent /kiviq
ENTRYPOINT ["/kiviq"]
