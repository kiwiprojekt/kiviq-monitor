FROM golang:1.26.4-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY cmd/ cmd/
COPY internal/ internal/
RUN CGO_ENABLED=0 go build -o /kiviq-monitor ./cmd/monitor

FROM node:20-alpine AS frontend
WORKDIR /web
COPY web/package*.json ./
RUN npm ci
COPY web/ .
RUN npm run build

FROM alpine:3.19
RUN apk add --no-cache ca-certificates
COPY --from=build /kiviq-monitor /kiviq
COPY --from=frontend /web/dist /app/web/dist
EXPOSE 9753
ENTRYPOINT ["/kiviq"]
